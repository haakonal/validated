{
    "name": "Python 3 & UV",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/constraints/.venv/bin/python",
                "files.eol": "\r\n"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "astral-sh.ruff",
                "eamodio.gitlens"
            ]
        }
    },
    "postCreateCommand": "pip install uv && uv sync"
}
